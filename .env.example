PORT=3020
CORS_ORIGIN=http://localhost:3020
DEMO_MODE=false

# ========== 数据库配置 ==========
# DB_TYPE: mysql（需要安装 MySQL）| sqlite（内嵌数据库，无需安装，适合 .exe 分发）
DB_TYPE=sqlite

# MySQL 配置（仅 DB_TYPE=mysql 时需要）
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=123456
DB_NAME=edu_smart

JWT_SECRET=replace_me_in_production
JWT_EXPIRES_IN=24h

# ========== 讯飞星火大模型（推荐作为主 LLM） ==========
# 在 https://console.xfyun.cn/ 创建应用，获取 API Key/Secret
# 注意：SPARK_API_KEY_SECRET 格式为 {APIKey}:{APISecret}（用冒号连接）
SPARK_APP_ID=
SPARK_API_KEY=
SPARK_API_SECRET=
SPARK_API_KEY_SECRET=your_api_key:your_api_secret
SPARK_HTTP_API=https://spark-api-open.xf-yun.com/v1/chat/completions
SPARK_MODEL=lite

# ========== LLM 网关配置 ==========
# provider: spark(星火) | local(本地部署) | herdsman(本地模型管理)
LLM_PROVIDER=spark
# 当 provider 不是 spark 时，是否允许本地模型失败后回退到星火
LLM_ALLOW_SPARK_FALLBACK=true
# 星火 API 密码（与 SPARK_API_KEY_SECRET 相同格式）
SEARCH_API_PASSWORD=your_api_key:your_api_secret

# ========== 本地模型（仅 LLM_PROVIDER=local 时生效） ==========
LOCAL_LLM_BASE_URL=http://127.0.0.1:8080/v1
LOCAL_LLM_MODEL=DeepSeek-R1-Distill:Qwen-1.5B
LOCAL_LLM_API_KEY=local
LOCAL_LLM_TIMEOUT_MS=60000
LOCAL_LLM_MAX_TOKENS=2048
LOCAL_LLM_TEMPERATURE=0.4

# herdsman 本地模型管理（覆盖 local 配置）
# HERDSMAN_BASE_URL=http://127.0.0.1:8080/v1
# HERDSMAN_MODEL=你的模型名
# HERDSMAN_API_KEY=local
# HERDSMAN_MAX_TOKENS=4096
# HERDSMAN_TEMPERATURE=0.4
# HERDSMAN_TIMEOUT_MS=120000

MEMBERSHIP_DEMO_ENABLED=true
DAILY_DIGEST_DEFAULT_TIME=08:00
APP_PUBLIC_URL=http://localhost:3020

# 邮件发送配置。QQ 邮箱发件请在 QQ 邮箱设置中开启 SMTP，并使用“授权码”作为 SMTP_PASSWORD。
EMAIL_PROVIDER=smtp
EMAIL_FROM=EduSmart <3415647252@qq.com>
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=3415647252@qq.com
SMTP_PASSWORD=atcbxzvvzrnmdaab

EMBEDDING_PROVIDER=local
EMBEDDING_BASE_URL=http://127.0.0.1:11434/v1
EMBEDDING_MODEL=text2vec-base-chinese
EMBEDDING_API_KEY=local
EMBEDDING_TIMEOUT_MS=30000
EMBEDDING_DIMENSIONS=768

CHROMA_URL=http://127.0.0.1:8000
CHROMA_COLLECTION=edusmart_rag
CHROMA_TIMEOUT_MS=30000


XFYUN_APP_ID=
XFYUN_API_KEY=
XFYUN_API_SECRET=
XFYUN_IAT_WS_API=wss://iat-api.xfyun.cn/v2/iat
XFYUN_IMAGE_WS_API=wss://spark-api.cn-huabei-1.xf-yun.com/v2.1/image
XFYUN_PPT_API_URL=https://zwapi.xfyun.cn/api/ppt/v2/create

XFYUN_OCR_APP_ID=
XFYUN_OCR_API_KEY=
XFYUN_OCR_API_SECRET=
XFYUN_OCR_API_URL=https://cbm01.cn-huabei-1.xf-yun.com/v1/private/se75ocrbm
